{
	"name": "eleventy-starter",
	"version": "0.0.1",
	"description": "A basic scaffolding for building 11ty static websites.",
	"type": "module",
	"scripts": {
		"dev": "eleventy --serve",
		"build": "eleventy",
		"format": "prettier --write .",
		"lint:js": "cross-env DEBUG=eslint:eslint-helpers eslint",
		"lint:css": "stylelint -f verbose \"./src/**/*.{css,scss}\"",
		"lint:md": "markdownlint-cli2",
		"lint": "npm run format &&  npm run lint:js && npm run lint:css && npm run lint:md",
		"clean": "del-cli '_site' '.11ty-vite'"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/artislismanis/eleventy-starter.git"
	},
	"keywords": [
		"11ty",
		"vite",
		"static site generator"
	],
	"author": "Artis Lismanis",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/artislismanis/eleventy-starter/issues"
	},
	"homepage": "https://github.com/artislismanis/eleventy-starter#readme",
	"engines": {
		"node": ">=22"
	},
	"devDependencies": {
		"@11ty/eleventy": "^3.1.2",
		"@11ty/eleventy-img": "^6.0.4",
		"@11ty/eleventy-navigation": "^1.0.4",
		"@11ty/eleventy-plugin-rss": "^2.0.4",
		"@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
		"@11ty/eleventy-plugin-vite": "^7.0.0",
		"autoprefixer": "^10.4.21",
		"cross-env": "^10.0.0",
		"cssnano": "^7.1.1",
		"del-cli": "^7.0.0",
		"eslint": "^9.36.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-promise": "^7.2.1",
		"globals": "^16.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.0",
		"luxon": "^3.7.2",
		"markdown-it": "^14.1.0",
		"markdown-it-anchor": "^9.2.0",
		"markdownlint": "^0.38.0",
		"markdownlint-cli2": "^0.18.1",
		"postcss-nesting": "^13.0.2",
		"postcss-scss": "^4.0.9",
		"prettier": "^3.6.2",
		"prettier-plugin-jinja-template": "^2.1.0",
		"sass-embedded": "^1.93.0",
		"stylelint": "^16.24.0",
		"stylelint-config-standard-scss": "^16.0.0",
		"stylelint-scss": "^6.12.1",
		"vite": "^7.1.7",
		"vite-plugin-eslint": "^1.8.1",
		"vite-plugin-stylelint": "^6.0.2",
		"zod": "^4.1.11",
		"zod-validation-error": "^4.0.2"
	}
}
